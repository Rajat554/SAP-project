{
  "_version": "1.12.0",
  "sap.app": {
    "id": "sap.ui.demo.walkthrough",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/wash-wizard/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbound": {
        "WashWizard-manage": {
          "semanticObject": "WashWizard",
          "action": "manage",
          "title": "WashWizard Manager",
          "subTitle": "Car Wash Center",
          "icon": "sap-icon://car-facade"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "supportedThemes": [
      "sap_horizon"
    ]
  },
  "sap.ui5": {
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "rootView": {
      "viewName": "sap.ui.demo.walkthrough.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.tnt": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.uxap": {},
        "sap.viz": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.ui.demo.walkthrough.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "refreshAfterChange": true
        }
      },
      "PricingData": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/PricingData.json"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "sap.ui.demo.walkthrough.view",
        "controlId": "idContentApp",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "dashboard",
          "target": "dashboard"
        },
        {
          "pattern": "service-records",
          "name": "serviceRecords",
          "target": "serviceRecords"
        },
        {
          "pattern": "analytics",
          "name": "analytics",
          "target": "analytics"
        },
        {
          "pattern": "settings",
          "name": "settings",
          "target": "settings"
        }
      ],
      "targets": {
        "dashboard": {
          "viewId": "dashboard",
          "viewName": "Dashboard"
        },
        "serviceRecords": {
          "viewId": "serviceRecords",
          "viewName": "ServiceRecords"
        },
        "analytics": {
          "viewId": "analytics",
          "viewName": "Analytics"
        },
        "settings": {
          "viewId": "settings",
          "viewName": "Settings"
        }
      }
    }
  }
}