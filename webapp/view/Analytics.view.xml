<mvc:View
	controllerName="sap.ui.demo.walkthrough.controller.Analytics"
	xmlns:mvc="sap.ui.core.mvc"
	displayBlock="true"
	xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

	<Page id="idAnalyticsPage" title="Income Analytics" showHeader="false" class="sapUiResponsiveContentPadding">
		<VBox class="sapUiSmallMargin">
            <!-- Header Section -->
            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom customHeader">
                <VBox>
                    <Title text="Income Analytics" level="H2" titleStyle="H2" class="pageTitle" />
                    <Text text="Track revenue trends and service performance" class="sapUiTinyMarginTop greyText" />
                </VBox>
                <HBox alignItems="Center">
                    <DatePicker id="idMonthDatePicker" displayFormat="MMMM yyyy" valueFormat="yyyy-MM" change=".onDatePickerMonthChange" width="12rem" class="sapUiSmallMarginEnd" />
                </HBox>
            </HBox>

            <!-- KPI Cards Section -->
            <l:Grid class="sapUiSmallMarginBottom">
                <!-- Total Revenue -->
                <VBox class="sapUiSmallMargin customWhiteCard">
                    <HBox justifyContent="SpaceBetween">
                        <Text text="Total Revenue" class="sapMTextBold" />
                        <core:Icon src="sap-icon://lead" color="#888" />
                    </HBox>
                    <HBox alignItems="Baseline" class="sapUiSmallMarginTop">
                        <Title text="₹{analyticsModel>/totalRevenue}" level="H1" titleStyle="H1" />
                    </HBox>
                    <Text text="This month's total" class="sapUiTinyMarginTop greyText smallText" />
                </VBox>

                <!-- Total Services -->
                <VBox class="sapUiSmallMargin customWhiteCard">
                    <HBox justifyContent="SpaceBetween">
                        <Text text="Total Services" class="sapMTextBold" />
                        <core:Icon src="sap-icon://group" color="#888" />
                    </HBox>
                    <HBox alignItems="Baseline" class="sapUiSmallMarginTop">
                        <Title text="{analyticsModel>/totalServices}" level="H1" titleStyle="H1" />
                    </HBox>
                    <Text text="Services completed" class="sapUiTinyMarginTop greyText smallText" />
                </VBox>

                <!-- Avg Daily Revenue -->
                <VBox class="sapUiSmallMargin customWhiteCard">
                    <HBox justifyContent="SpaceBetween">
                        <Text text="Avg Daily Revenue" class="sapMTextBold" />
                        <core:Icon src="sap-icon://trend-up" color="#888" />
                    </HBox>
                    <HBox alignItems="Baseline" class="sapUiSmallMarginTop">
                        <Title text="₹{analyticsModel>/avgDailyRevenue}" level="H1" titleStyle="H1" />
                    </HBox>
                    <Text text="Per working day" class="sapUiTinyMarginTop greyText smallText" />
                </VBox>

                <!-- Avg Service Value -->
                <VBox class="sapUiSmallMargin customWhiteCard">
                    <HBox justifyContent="SpaceBetween">
                        <Text text="Avg Service Value" class="sapMTextBold" />
                        <core:Icon src="sap-icon://bar-chart" color="#888" />
                    </HBox>
                    <HBox alignItems="Baseline" class="sapUiSmallMarginTop">
                        <Title text="₹{analyticsModel>/avgServiceValue}" level="H1" titleStyle="H1" />
                    </HBox>
                    <Text text="Revenue per service" class="sapUiTinyMarginTop greyText smallText" />
                </VBox>
            </l:Grid>

            <!-- Tabs Section -->
            <IconTabBar id="idAnalyticsIconTabBar" class="sapUiResponsiveContentPadding customPanel">
                <items>
                    <IconTabFilter text="Revenue Trends" key="trends">
                        <VBox class="sapUiSmallMargin customCardContainer">
                            <VBox class="sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://business-objects-experience" class="sapUiTinyMarginEnd" color="#888" />
                                    <Title text="Daily Revenue Overview" level="H3" titleStyle="H3" />
                                </HBox>
                                <Text text="Revenue breakdown for selected month" class="greyText smallText sapUiTinyMarginTop" />
                            </VBox>
                            <viz:VizFrame id="idLineVizFrame" uiConfig="{applicationSet:'fiori'}" height="400px" width="100%" vizType="line">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{analyticsModel>/revenueTrendData}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Date" value="{analyticsModel>Day}" />
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Revenue" value="{analyticsModel>Revenue}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue" />
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                                </viz:feeds>
                            </viz:VizFrame>
                        </VBox>
                        
                        <VBox class="sapUiSmallMarginTop customWhiteCard">
                            <VBox class="sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://trend-up" class="sapUiTinyMarginEnd" color="#888" />
                                    <Title text="Services Count Trend" level="H3" titleStyle="H3" />
                                </HBox>
                                <Text text="Daily service count for selected month" class="greyText smallText sapUiTinyMarginTop" />
                            </VBox>
                            <viz:VizFrame id="idLineCountVizFrame" uiConfig="{applicationSet:'fiori'}" height="300px" width="100%" vizType="line">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{analyticsModel>/revenueTrendData}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Date" value="{analyticsModel>Day}" />
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Services" value="{analyticsModel>ServiceCount}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Services" />
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date" />
                                </viz:feeds>
                            </viz:VizFrame>
                        </VBox>
                    </IconTabFilter>

                    <IconTabFilter text="Service Distribution" key="distribution">
                        <l:Grid defaultSpan="XL6 L6 M12 S12">
                            <!-- Pie Chart -->
                            <VBox class="sapUiSmallMargin customCardContainer">
                                <VBox class="sapUiSmallMarginBottom">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://pie-chart" class="sapUiTinyMarginEnd" color="#888" />
                                        <Title text="Service Type Distribution" level="H3" titleStyle="H3" />
                                    </HBox>
                                    <Text text="Revenue breakdown by service type" class="greyText smallText sapUiTinyMarginTop" />
                                </VBox>
                                <viz:VizFrame id="idPieVizFrame" uiConfig="{applicationSet:'fiori'}" height="300px" width="100%" vizType="pie">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{analyticsModel>/serviceDistributionData}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="ServiceType" value="{analyticsModel>ServiceType}" />
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Revenue" value="{analyticsModel>Revenue}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="size" type="Measure" values="Revenue" />
                                        <viz.feeds:FeedItem uid="color" type="Dimension" values="ServiceType" />
                                    </viz:feeds>
                                </viz:VizFrame>
                            </VBox>

                            <!-- Column Chart -->
                            <VBox class="sapUiSmallMargin customCardContainer">
                                <VBox class="sapUiSmallMarginBottom">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://vertical-bar-chart" class="sapUiTinyMarginEnd" color="#888" />
                                        <Title text="Service Volume by Type" level="H3" titleStyle="H3" />
                                    </HBox>
                                    <Text text="Number of services by type" class="greyText smallText sapUiTinyMarginTop" />
                                </VBox>
                                <viz:VizFrame id="idColumnVizFrame" uiConfig="{applicationSet:'fiori'}" height="300px" width="100%" vizType="column">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{analyticsModel>/serviceDistributionData}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="ServiceType" value="{analyticsModel>ServiceType}" />
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Volume" value="{analyticsModel>Count}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Volume" />
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="ServiceType" />
                                    </viz:feeds>
                                </viz:VizFrame>
                            </VBox>
                        </l:Grid>
                    </IconTabFilter>

                    <IconTabFilter text="Performance" key="performance">
                        <l:Grid defaultSpan="XL6 L6 M12 S12">
                            <!-- Top Services List -->
                            <VBox class="sapUiSmallMargin customCardContainer">
                                <VBox class="sapUiSmallMarginBottom">
                                    <Title text="Top Performing Services" level="H3" titleStyle="H3" />
                                    <Text text="Services by revenue generation" class="greyText smallText sapUiTinyMarginTop" />
                                </VBox>
                                <List items="{analyticsModel>/performanceMetrics/topServices}" class="customServiceList">
                                    <CustomListItem>
                                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMargin">
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://circle-task-2" color="#0070F2" class="sapUiTinyMarginEnd" size="0.6rem" />
                                                <Text text="{analyticsModel>ServiceType}" class="sapMTextBold" />
                                            </HBox>
                                            <VBox alignItems="End">
                                                <Text text="₹{analyticsModel>Revenue}" class="sapMTextBold" />
                                                <Text text="{analyticsModel>Count} services" class="greyText smallText" />
                                            </VBox>
                                        </HBox>
                                    </CustomListItem>
                                </List>
                            </VBox>

                            <!-- Performance Metrics -->
                            <VBox class="sapUiSmallMargin customCardContainer">
                                <VBox class="sapUiSmallMarginBottom">
                                    <Title text="Performance Metrics" level="H3" titleStyle="H3" />
                                    <Text text="Key business indicators" class="greyText smallText sapUiTinyMarginTop" />
                                </VBox>
                                <VBox>
                                    <!-- Best Performing Day -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="metricRow sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd customListRow">
                                        <Text text="Best Performing Day" />
                                        <Text text="{analyticsModel>/performanceMetrics/bestDayDate}" class="sapMTextBold" />
                                    </HBox>
                                    <!-- Peak Revenue Day -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="metricRow sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd customListRow">
                                        <Text text="Peak Revenue Day" />
                                        <Text text="₹{analyticsModel>/performanceMetrics/peakRevenue}" class="sapMTextBold" />
                                    </HBox>
                                    <!-- Busiest Day -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="metricRow sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd customListRow">
                                        <Text text="Busiest Day" />
                                        <Text text="{analyticsModel>/performanceMetrics/busiestDayServices} services" class="sapMTextBold" />
                                    </HBox>
                                    <!-- Working Days -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="metricRow sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd customListRow">
                                        <Text text="Working Days" />
                                        <Text text="{analyticsModel>/performanceMetrics/workingDays} days" class="sapMTextBold" />
                                    </HBox>
                                    <!-- Most Popular Service -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="metricRow sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd customListRow">
                                        <Text text="Most Popular Service" />
                                        <Text text="{analyticsModel>/performanceMetrics/topServiceType}" class="sapMTextBold" />
                                    </HBox>
                                </VBox>
                            </VBox>
                        </l:Grid>
                    </IconTabFilter>
                </items>
            </IconTabBar>
		</VBox>
	</Page>
</mvc:View>
