<mvc:View
	controllerName="sap.ui.demo.walkthrough.controller.Settings"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page
		id="idSettingsPage"
		showHeader="false"
		class="dashboardBackground">
		<content>
			<VBox class="sapUiMediumMargin">
				<Title text="Settings" class="dashboardTitle sapUiTinyMarginBottom" />
				<Text text="Manage your account settings and preferences" class="userEmailText sapUiMediumMarginBottom" />
				
				<IconTabBar
					id="idIconTabBar"
					selectedKey="profile"
					class="customTabBar"
					expandable="false"
					applyContentPadding="false">
					<items>
						<IconTabFilter key="profile" text="Profile" icon="sap-icon://person-placeholder" class="tabFilterButton">
							
							<!-- Profile Information Block -->
							<VBox class="customWhiteCard sapUiMediumMarginBottom sapUiSmallMarginTop">
								<VBox class="sapUiSmallMargin">
									<HBox alignItems="Center" class="sapUiSmallMarginBottom">
										<core:Icon src="sap-icon://person-placeholder" size="1.2rem" class="sapUiTinyMarginEnd" color="#555" />
										<Title text="Profile Information" level="H3" titleStyle="H3" class="cardTitle" />
									</HBox>
									<Text text="Update your personal information and account details" class="userEmailText sapUiMediumMarginBottom" />
									
									<form:SimpleForm
										editable="true"
										labelSpanXL="12" labelSpanL="12" labelSpanM="12"
										adjustLabelSpan="false"
										columnsXL="2" columnsL="2" columnsM="2"
										singleContainerFullSize="false"
										class="sapUiNoContentPadding">
										<form:content>
											<core:Title />
											<Label text="Full Name" class="customLabel" />
											<Input value="Demo User" placeholder="Enter Full Name" class="customInput" />
											<core:Title />
											<Label text="Email Address" class="customLabel" />
											<Input value="demo@carwash.com" placeholder="Enter Email Address" class="customInput" />
										</form:content>
									</form:SimpleForm>
								</VBox>
							</VBox>

							<!-- Change Password Block -->
							<VBox class="customWhiteCard sapUiMediumMarginBottom">
								<VBox class="sapUiSmallMargin">
									<Title text="Change Password" level="H3" titleStyle="H3" class="cardTitle sapUiSmallMarginBottom" />
									
									<form:SimpleForm
										editable="true"
										labelSpanXL="12" labelSpanL="12" labelSpanM="12"
										adjustLabelSpan="false"
										columnsXL="3" columnsL="3" columnsM="3"
										singleContainerFullSize="false"
										class="sapUiNoContentPadding">
										<form:content>
											<core:Title />
											<Label text="Current Password" class="customLabel" />
											<Input type="Password" placeholder="Enter current password" class="customInput" />
											
											<core:Title />
											<Label text="New Password" class="customLabel" />
											<Input type="Password" placeholder="Enter new password" class="customInput" />
											
											<core:Title />
											<Label text="Confirm Password" class="customLabel" />
											<Input type="Password" placeholder="Confirm new password" class="customInput" />
										</form:content>
									</form:SimpleForm>
								</VBox>
							</VBox>
							
							<HBox>
								<Button text="Save Changes" press=".onSaveChangesButtonPress" class="customSaveBtn" icon="sap-icon://save" width="150px" />
							</HBox>
						</IconTabFilter>

						<IconTabFilter text="Notifications" icon="sap-icon://bell" key="notifications" class="tabFilterButton">
							<VBox class="customWhiteCard sapUiSmallMarginTop">
								<Text text="Notification settings will be available here." class="sapUiSmallMargin"/>
							</VBox>
						</IconTabFilter>
						
						<IconTabFilter text="Preferences" icon="sap-icon://palette" key="preferences" class="tabFilterButton">
							<VBox class="customWhiteCard sapUiSmallMarginTop">
								<Text text="Preferences settings will be available here." class="sapUiSmallMargin"/>
							</VBox>
						</IconTabFilter>
						
						<IconTabFilter text="Users" icon="sap-icon://group" key="users" class="tabFilterButton">
							<VBox class="customWhiteCard sapUiSmallMarginTop">
								<Text text="User management will be available here." class="sapUiSmallMargin"/>
							</VBox>
						</IconTabFilter>

						<IconTabFilter text="Security" icon="sap-icon://shield" key="security" class="tabFilterButton">
							<VBox class="customWhiteCard sapUiSmallMarginTop">
								<Text text="Security settings will be available here." class="sapUiSmallMargin"/>
							</VBox>
						</IconTabFilter>
					</items>
				</IconTabBar>
			</VBox>
		</content>
	</Page>
</mvc:View>
