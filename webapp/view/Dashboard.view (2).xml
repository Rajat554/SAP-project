<mvc:View
	controllerName="sap.ui.demo.walkthrough.controller.Dashboard"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">

	<Page id="idDashboardPage" showHeader="false" class="dashboardBackground">
		
		<!-- Top Title Area -->
		<!-- <HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="responsivePadding sapUiMediumMarginTop sapUiMediumMarginBottom">
			<Title text="Dashboard" level="H1" class="dashboardTitle"/>
			<HBox alignItems="Center">
				<core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#333"/>
				<Text text="{viewModel>/currentDate}" class="dateText"/>
			</HBox>
		</HBox> -->

		<!-- Tabs -->
		<IconTabBar id="idIconTabBar" class="responsivePadding customTabBar" stretchContentHeight="true">
			<items>
				<IconTabFilter text="Service Entry" key="entry" class="tabFilterButton">
					
					<!-- The 3 Column Form Layout -->
					<!-- Wrapped in a VBox with MarginEnd to prevent overflow clipping -->
					<VBox class="pbEdgePadding">
						<l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" class="sapUiSmallMarginTop">
							
							<!-- Column 1: Contact Details -->
							<VBox class="cardBox flexColumn">
								<HBox alignItems="Center" class="sapUiMediumMarginBottom">
									<core:Icon src="sap-icon://customer" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
									<Title text="Contact Details" level="H3" class="cardTitle"/>
								</HBox>
								<Label text="Customer Name" required="true" class="customLabel"/>
								<Input id="idRajatPatelInput" value="Rajat Patel" class="customInput sapUiSmallMarginBottom"/>
								
								<Label text="Phone Number" required="true" class="customLabel"/>
								<Input value="2004550121" class="customInput sapUiSmallMarginBottom"/>

								<Label text="Address" required="true" class="customLabel"/>
								<Input value="0x372f5c9f040bdec4798b950dd7c02aee0812b362" class="customInput sapUiSmallMarginBottom"/>

								<Label text="Car Model Name" required="true" class="customLabel"/>
								<Input value="car1" class="customInput sapUiSmallMarginBottom"/>

								<Label text="Vehicle Number" required="true" class="customLabel"/>
								<Input id="idVehicleInput" value="" class="customInput sapUiSmallMarginBottom"/>
							</VBox>

							<!-- Column 2: Service Details -->
							<VBox class="cardBox flexColumn">
								<HBox alignItems="Center" class="sapUiMediumMarginBottom">
									<core:Icon src="sap-icon://car-rental" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
									<Title text="Service Details" level="H3" class="cardTitle"/>
								</HBox>
								<Label text="No. of Wheels" required="true" class="customLabel"/>
								<Select selectedKey="2 Wheeler" class="customInput sapUiMediumMarginBottom" width="100%">
									<core:Item key="2 Wheeler" text="2 Wheeler"/>
									<core:Item key="4 Wheeler" text="4 Wheeler"/>
								</Select>

								<Label text="Service Types (Select multiple)" required="true" class="customLabel"/>
								
								<!-- Panel for Washing Checkboxes -->
								<Panel expandable="true" expanded="true" headerText="Washing" width="auto" class="servicePanel sapUiSmallMarginBottom">
									<VBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Full Wash" select=".onFullWashCheckBoxSelect" app:price="200"/>
											<Text text="₹200" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Half Wash" select=".onHalfWashCheckBoxSelect" app:price="100"/>
											<Text text="₹100" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Top Wash" select=".onTopWashCheckBoxSelect" app:price="120"/>
											<Text text="₹120" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Water Wash" select=".onWaterWashCheckBoxSelect" app:price="140"/>
											<Text text="₹140" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Deseil Wash" select=".onDeseilWashCheckBoxSelect" app:price="150"/>
											<Text text="₹150" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Oil Spare" select=".onOilSpareCheckBoxSelect" app:price="80"/>
											<Text text="₹80" class="priceText"/>
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
											<CheckBox text="Washing &amp; Gressing" select=".onWashingAmpGressingCheckBoxSelect" app:price="200"/>
											<Text text="₹200" class="priceText"/>
										</HBox>
									</VBox>
								</Panel>

								<!-- Placeholder for Coating Panel -->
								<Panel expandable="true" headerText="Coating" width="auto" class="servicePanel">
								</Panel>
							</VBox>

							<!-- Column 3: Payment Details -->
							<VBox class="cardBox flexColumn" justifyContent="SpaceBetween">
								<VBox>
									<HBox alignItems="Center" class="sapUiMediumMarginBottom">
										<core:Icon src="sap-icon://credit-card" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
										<Title text="Payment Details" level="H3" class="cardTitle"/>
									</HBox>
									
									<Label text="Amount" required="true" class="customLabel"/>
									<Input id="idAmountInput" value="0" class="customInput sapUiSmallMarginBottom amountField" editable="false"/>

									<Label text="Payment Method" required="true" class="customLabel"/>
									<Select selectedKey="Online" width="100%" class="customInput">
										<core:Item key="Online" text="Online"/>
										<core:Item key="Cash" text="Cash"/>
									</Select>
								</VBox>

								<!-- Spacer to push button down -->
								<ToolbarSpacer/>
								<Button text="Save Service" width="100%" class="sapUiMediumMarginTop customSaveBtn" press=".onSaveServiceButtonPress" icon="sap-icon://save"/>
							</VBox>
						</l:Grid>
					</VBox>
				</IconTabFilter>

				<IconTabFilter text="Current Services ({viewModel>/servicesCount})" key="current" class="tabFilterButton">
					<List id="idServicesList" items="{ServiceData>/Services}" class="sapUiSmallMarginTop noStandardBackgroundList">
						<items>
							<CustomListItem class="sapUiSmallMarginBottom currentServiceCard">
								<HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="responsiveServiceHBox">
									<!-- Left: Customer info -->
									<HBox alignItems="Center">
										<core:Icon src="sap-icon://car-rental" class="carIconCircle sapUiMediumMarginEnd"/>
										<VBox>
											<Text text="{ServiceData>CustomerName}" class="customerNameText"/>
											<Text text="{ServiceData>CarPlate}" class="vehicleNumberText"/>
										</VBox>
									</HBox>
									
									<!-- Middle: Service and Amount -->
									<HBox wrap="Wrap" justifyContent="Center" class="serviceInfoBox responsiveServiceInfo">
										<VBox alignItems="Center" class="sapUiLargeMarginEnd">
											<Text text="Service" class="metaLabel"/>
											<Text text="{= ${ServiceData>ServiceType} ? ${ServiceData>ServiceType} : 'Basic Wash' }" class="metaValue"/>
										</VBox>
										<VBox alignItems="Center">
											<Text text="Amount" class="metaLabel"/>
											<Text text="₹{= ${ServiceData>Amount} !== undefined ? ${ServiceData>Amount} : 200}" class="metaValue"/>
										</VBox>
									</HBox>

									<!-- Right: Actions -->
									<HBox alignItems="Center">
										<Button icon="sap-icon://edit" type="Transparent" press=".onButtonEditPress" class="actionBtn sapUiTinyMarginEnd"/>
										<Button icon="sap-icon://delete" type="Transparent" press=".onButtonDeletePress" class="actionBtn sapUiTinyMarginEnd"/>
										<Button text="Complete" icon="sap-icon://accept" type="Emphasized" press=".onCompleteButtonPress" class="completeBtn"/>
									</HBox>
								</HBox>
							</CustomListItem>
						</items>
					</List>
				</IconTabFilter>
			</items>
		</IconTabBar>
	</Page>
</mvc:View>
