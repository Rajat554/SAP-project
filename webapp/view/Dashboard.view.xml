<mvc:View controllerName="sap.ui.demo.walkthrough.controller.Dashboard"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout">

	<Page id="idDashboardPage" showHeader="false" class="dashboardBackground">

		<!-- Tabs -->
		<IconTabBar id="idIconTabBar" class="responsivePadding customTabBar" stretchContentHeight="true">
			<items>

				<!-- ═══════════════════════════════════════════════
				     TAB 1: Service Entry
				     All input fields have IDs so the controller
				     can read and validate them on Save.
				     ═══════════════════════════════════════════════ -->
				<IconTabFilter text="Service Entry" key="entry" class="tabFilterButton">

					<l:Grid defaultSpan="XL4 L4 M12 S12" class="sapUiSmallMarginTop">

						<!-- Column 1: Contact Details -->
						<VBox class="cardBox flexColumn w-100">
							<HBox alignItems="Center" class="sapUiMediumMarginBottom">
								<core:Icon src="sap-icon://customer" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
								<Title text="Contact Details" level="H3" class="cardTitle"/>
							</HBox>
							<Label text="Customer Name" required="true" class="customLabel"/>
							<Input id="idCustomerNameInput" placeholder="e.g. Rajat Patel" class="customInput sapUiSmallMarginBottom" liveChange=".onInputLiveChange"/>

							<Label text="Phone Number" required="true" class="customLabel"/>
							<Input id="idPhoneInput" placeholder="10-digit mobile number" maxLength="10" class="customInput sapUiSmallMarginBottom" liveChange=".onInputLiveChange"/>

							<Label text="Car Model Name" required="true" class="customLabel"/>
							<Input id="idCarModelInput" placeholder="e.g. Honda City" class="customInput sapUiSmallMarginBottom" liveChange=".onInputLiveChange"/>

							<Label text="Vehicle Plate Number" required="true" class="customLabel"/>
							<!-- Placeholder shows the accepted Indian format -->
							<Input id="idVehiclePlateInput" placeholder="e.g. GJ 05 AR 4521" class="customInput sapUiSmallMarginBottom" liveChange=".onInputLiveChange"/>
						</VBox>

						<!-- Column 2: Service Details -->
						<VBox class="cardBox flexColumn w-100">
							<HBox alignItems="Center" class="sapUiMediumMarginBottom">
								<core:Icon src="sap-icon://car-rental" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
								<Title text="Service Details" level="H3" class="cardTitle"/>
							</HBox>
							<Label text="No. of Wheels" required="true" class="customLabel"/>
							<Select id="idWheelSelect" selectedKey="{viewModel>/selectedWheels}" change=".onSelectChange" class="customInput sapUiMediumMarginBottom" width="100%">
								<core:Item key="2 Wheeler" text="2 Wheeler"/>
								<core:Item key="3 Wheeler" text="3 Wheeler"/>
								<core:Item key="4 Wheeler" text="4 Wheeler"/>
								<core:Item key="6 Wheeler" text="6 Wheeler"/>
								<core:Item key="8 Wheeler" text="8 Wheeler"/>
								<core:Item key="10 Wheeler" text="10 Wheeler"/>
								<core:Item key="12 Wheeler" text="12 Wheeler"/>
								<core:Item key="14 Wheeler" text="14 Wheeler"/>
							</Select>
							<Label text="Service Types (Select multiple)" required="true" class="customLabel"/>
							<Panel expandable="true" expanded="true" headerText="Washing" width="auto" class="servicePanel sapUiSmallMarginBottom" visible="{= ${viewModel>/washingServices}.length > 0 }">
								<List id="idWashingServicesList" items="{viewModel>/washingServices}" mode="MultiSelect" selectionChange=".onWashingServicesListSelectionChange">
									<StandardListItem title="{viewModel>name}" info="₹{viewModel>price}" />
								</List>
							</Panel>
							<Panel expandable="true" expanded="true" headerText="Interior" width="auto" class="servicePanel sapUiSmallMarginBottom" visible="{= ${viewModel>/interiorServices}.length > 0 }">
								<List id="idInteriorServicesList" items="{viewModel>/interiorServices}" mode="MultiSelect" selectionChange=".onInteriorServicesListSelectionChange">
									<StandardListItem title="{viewModel>name}" info="₹{viewModel>price}" />
								</List>
							</Panel>
							<Panel expandable="true" expanded="false" headerText="Coating" width="auto" class="servicePanel">
								<List id="idCoatingServicesList" items="{viewModel>/coatingServices}" mode="MultiSelect" selectionChange=".onCoatingServicesListSelectionChange">
									<StandardListItem title="{viewModel>name}" info="₹{viewModel>price}" />
								</List>
							</Panel>
						</VBox>

						<!-- Column 3: Payment Details -->
						<VBox class="cardBox flexColumn w-100" justifyContent="SpaceBetween">
							<VBox>
								<HBox alignItems="Center" class="sapUiMediumMarginBottom">
									<core:Icon src="sap-icon://credit-card" class="sapUiSmallMarginEnd iconTitle" color="#2B7CFF"/>
									<Title text="Payment Details" level="H3" class="cardTitle"/>
								</HBox>
								<Label text="Amount (auto-calculated)" required="true" class="customLabel"/>
								<!-- editable="true" lets user type amount manually if pricing panels are empty -->
								<Input id="idAmountInput" placeholder="Auto-calculated or enter manually" class="customInput sapUiSmallMarginBottom amountField" editable="true" type="Number"/>
								<Label text="Payment Method" required="true" class="customLabel"/>
								<Select id="idPaymentMethodSelect" selectedKey="Online" width="100%" class="customInput">
									<core:Item key="Online" text="Online"/>
									<core:Item key="Cash" text="Cash"/>
									<core:Item key="UPI" text="UPI"/>
									<core:Item key="Card" text="Card"/>
								</Select>
							</VBox>
							<ToolbarSpacer/>
							<!-- Save button triggers onSaveServiceButtonPress in the controller -->
							<Button id="idSaveServiceButton" text="Save Service" width="100%" class="sapUiMediumMarginTop customSaveBtn" press=".onSaveServiceButtonPress" icon="sap-icon://save"/>
						</VBox>

					</l:Grid>
				</IconTabFilter>

				<!-- ═══════════════════════════════════════════════
				     TAB 2: Current Services (Pending Queue)
				     The List is bound directly to the OData entity
				     set /ServiceTaskSet and filtered server-side
				     to show only Status='Pending' records.
				     ═══════════════════════════════════════════════ -->
				<IconTabFilter text="Current Services" key="current" class="tabFilterButton">
					<HBox class="sapUiSmallMarginBottom sapUiSmallMarginTop" alignItems="Center">
						<SearchField id="idDashboardSearchField" width="30rem" placeholder="Search by customer name or vehicle..." search=".onSearchFieldSearch" liveChange=".onSearchFieldLiveChange" class="sapUiSmallMarginEnd" />
					</HBox>
					<Panel class="customPanel" width="auto">
						<headerToolbar>
							<Toolbar design="Transparent">
								<core:Icon src="sap-icon://crm-service-manager" color="#0070F2" />
								<Title text="Current Services Queue" level="H3" titleStyle="H3" />
								<ToolbarSpacer />
								<Button icon="sap-icon://action-settings" press=".onButtonTableSettingsPress" type="Transparent" tooltip="Config Columns" />
							</Toolbar>
						</headerToolbar>

						<!-- Desktop Table — bound to JSON viewModel slice for pagination -->
						<Table id="idPendingServicesPageTable" items="{viewModel>/pendingServicesPage}" alternateRowColors="true" class="sapUiSizeCompact customServiceList hideOnMobile" noDataText="No pending services — all done!">
							<columns>
								<Column width="5%">
									<Text text="" />
								</Column>
								<Column width="22%">
									<Text text="Customer" class="sapMTextBold" />
								</Column>
								<Column width="18%" demandPopin="true" minScreenWidth="Tablet">
									<Text text="Vehicle" class="sapMTextBold" />
								</Column>
								<Column width="22%" demandPopin="true" minScreenWidth="Tablet">
									<Text text="Service" class="sapMTextBold" />
								</Column>
								<Column width="10%" hAlign="End" demandPopin="true" minScreenWidth="Tablet">
									<Text text="Amount" class="sapMTextBold" />
								</Column>
								<Column width="23%" hAlign="Center">
									<Text text="Actions" class="sapMTextBold" />
								</Column>
							</columns>
							<items>
								<ColumnListItem vAlign="Middle" class="customListRow">
									<cells>
										<core:Icon src="sap-icon://car-rental" color="#0070F2" />
										<VBox>
											<Text text="{viewModel>CustomerName}" class="sapMTextBold" />
											<Text text="{viewModel>Phone}" />
										</VBox>
										<VBox>
											<Text text="{viewModel>VehiclePlate}" class="sapMTextBold" />
											<Text text="{viewModel>CarModel}" />
										</VBox>
										<Text text="{viewModel>ServiceType}" />
										<Text text="₹{viewModel>Amount}" class="sapMTextBold" />
										<HBox justifyContent="Center" alignItems="Center">
											<Button icon="sap-icon://accept" type="Accept" text="Complete" press=".onCompleteButtonPress" class="sapUiTinyMarginBeginEnd" />
											<Button icon="sap-icon://edit" type="Emphasized" text="Edit" press=".onEditButtonPress" class="sapUiTinyMarginBeginEnd" tooltip="Edit Entry" />
											<Button icon="sap-icon://delete" type="Transparent" press=".onButtonDeletePress" tooltip="Delete" />
										</HBox>
									</cells>
								</ColumnListItem>
							</items>
						</Table>

						<!-- Pagination Bar for Desktop Table -->
						<Toolbar id="idPendingPaginationToolbar" class="sapUiSmallMarginTop">
							<ToolbarSpacer />
							<Button id="idPendingPrevPageButton" icon="sap-icon://navigation-left-arrow" press=".onButtonPendingPrevPagePress" type="Transparent" enabled="{= ${viewModel>/pendingCurrentPage} > 0}" tooltip="Previous Page" />
							<Text id="idPendingPageText" text="Page {= ${viewModel>/pendingCurrentPage} + 1} of {viewModel>/pendingTotalPages}" class="sapUiSmallMarginBeginEnd" />
							<Button id="idPendingNextPageButton" icon="sap-icon://navigation-right-arrow" press=".onButtonPendingNextPagePress" type="Transparent" enabled="{= (${viewModel>/pendingCurrentPage} + 1) &lt; ${viewModel>/pendingTotalPages}}" tooltip="Next Page" />
						</Toolbar>

						<!-- Mobile List -->
						<List id="idPendingServicesPageList" items="{viewModel>/pendingServicesPage}" class="stitchCardList showOnMobile sapUiSmallMarginTop" noDataText="No pending services">
							<items>
								<CustomListItem class="stitchCard">
									<VBox class="stitchFlex">
										<HBox justifyContent="SpaceBetween" alignItems="Start" class="stitchCardTop">
											<HBox>
												<core:Icon src="sap-icon://car-rental" class="stitchCheckIconWait" />
												<VBox class="stitchNameVBox">
													<Text text="{viewModel>CustomerName}" class="stitchCustomerName" />
													<Text text="{viewModel>VehiclePlate}" class="stitchCarPlate" />
												</VBox>
											</HBox>
											<VBox alignItems="End" class="stitchAmountVBox">
												<Text text="₹{viewModel>Amount}" class="stitchAmount" />
												<Text text="Pending" class="stitchPaymentPill pillPending" />
											</VBox>
										</HBox>
										<HBox class="stitchServicesSection">
											<Text text="Service: " class="stitchLabelText" />
											<Text text="{viewModel>ServiceType}" class="stitchMetaText" />
										</HBox>
										<HBox justifyContent="SpaceBetween" alignItems="Center" class="stitchButtonSection">
											<Button text="Delete" icon="sap-icon://delete" press=".onDeleteButtonPress" class="stitchActionBtn stitchActionBtnRed" />
											<Button text="Edit" icon="sap-icon://edit" press=".onEditButtonPress" class="stitchActionBtn stitchActionBtnBlue" />
											<Button text="Complete" icon="sap-icon://accept" press=".onCompleteButtonPress" class="stitchActionBtn stitchActionBtnGreen" />
										</HBox>
									</VBox>
								</CustomListItem>
							</items>
						</List>

						<!-- Mobile Pagination Bar -->
						<Toolbar id="idPendingMobilePaginationToolbar" class="showOnMobile sapUiSmallMarginTop">
							<ToolbarSpacer />
							<Button icon="sap-icon://navigation-left-arrow" press=".onButtonPendingPrevPagePress" type="Transparent" enabled="{= ${viewModel>/pendingCurrentPage} > 0}" />
							<Text text="Page {= ${viewModel>/pendingCurrentPage} + 1} of {viewModel>/pendingTotalPages}" class="sapUiSmallMarginBeginEnd" />
							<Button icon="sap-icon://navigation-right-arrow" press=".onButtonPendingNextPagePress" type="Transparent" enabled="{= (${viewModel>/pendingCurrentPage} + 1) &lt; ${viewModel>/pendingTotalPages}}" />
						</Toolbar>

					</Panel>
				</IconTabFilter>

			</items>
		</IconTabBar>
	</Page>
</mvc:View>
