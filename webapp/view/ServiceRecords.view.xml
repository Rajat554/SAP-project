<mvc:View controllerName="sap.ui.demo.walkthrough.controller.ServiceRecords"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page id="idServiceRecordsPage" title="Service Records" showHeader="false" class="sapUiResponsiveContentPadding">
        <VBox class="sapUiSmallMargin">
            <!-- Header Section -->
            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                <Title text="Service Records" level="H2" titleStyle="H2" />
                <HBox alignItems="Center">
                    <ObjectStatus text="{viewModel>/totalServices} Completed Services" inverted="true" state="Success" class="sapUiSmallMarginEnd customTag" />
                    <Button icon="sap-icon://synchronize" text="Refresh" press=".onRefreshButtonPress" />
                </HBox>
            </HBox>

            <!-- Search and Filter Section -->
            <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                <SearchField id="idRecordsSearchField" width="30rem" placeholder="Search by customer name, vehicle number, or phone..." search=".onSearchFieldSearch" liveChange=".onSearchFieldLiveChange" class="sapUiSmallMarginEnd" />
                <ComboBox id="idPaymentComboBox" placeholder="Payment Method" selectionChange=".onComboBoxSelectionChange" class="sapUiSmallMarginEnd">
                    <core:Item key="All" text="All Payments" />
                    <core:Item key="UPI" text="UPI" />
                    <core:Item key="Card" text="Card" />
                    <core:Item key="Cash" text="Cash" />
                </ComboBox>
                <ComboBox id="idServiceComboBox" placeholder="Service Type" selectionChange=".onComboBoxSelectionChange">
                    <core:Item key="All" text="All Services" />
                    <core:Item key="Full Wash" text="Full Wash" />
                    <core:Item key="Interior Cleaning" text="Interior Cleaning" />
                    <core:Item key="Premium Wash" text="Premium Wash" />
                </ComboBox>
            </HBox>

            <!-- List Section -->
            <Panel class="customPanel" width="auto">
                <headerToolbar>
                    <Toolbar design="Transparent">
                        <core:Icon src="sap-icon://crm-service-manager" color="#0070F2" />
                        <Title text="Completed Services" level="H3" titleStyle="H3" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://action-settings" press=".onButtonTableSettingsPress" type="Transparent" tooltip="Config Columns" />
                        <Text text="{viewModel>/pageHeaderInfo}" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                    </Toolbar>
                </headerToolbar>

                <Table id="idPagedServicesTable" items="{viewModel>/pagedServices}" noDataText="No matching service records found." alternateRowColors="true" class="sapUiSizeCompact customServiceList hideOnMobile">
                    <columns>
                        <Column width="16%" visible="{viewModel>/tableColumns/Customer}">
                            <Text text="Customer" class="sapMTextBold" />
                        </Column>
                        <Column width="16%" visible="{viewModel>/tableColumns/Vehicle}">
                            <Text text="Vehicle" class="sapMTextBold" />
                        </Column>
                        <Column width="10%" demandPopin="true" minScreenWidth="Tablet" visible="{viewModel>/tableColumns/Services}">
                            <Text text="Services" class="sapMTextBold" />
                        </Column>
                        <Column width="11%" demandPopin="true" minScreenWidth="Tablet" hAlign="Center" visible="{viewModel>/tableColumns/Payment}">
                            <Text text="Payment" class="sapMTextBold" />
                        </Column>
                        <Column width="10%" demandPopin="true" minScreenWidth="Tablet" hAlign="Center" visible="{viewModel>/tableColumns/Amount}">
                            <Text text="Amount" class="sapMTextBold" />
                        </Column>
                        <Column width="10%" demandPopin="true" minScreenWidth="Desktop" hAlign="Center" visible="{viewModel>/tableColumns/Date}">
                            <Text text="Date" class="sapMTextBold" />
                        </Column>
                        <Column width="10%" hAlign="Center" visible="{viewModel>/tableColumns/Actions}">
                            <Text text="Actions" class="sapMTextBold" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem vAlign="Middle" class="customListRow">
                            <cells>
                                <VBox>
                                    <Text text="{viewModel>CustomerName}" class="sapMTextBold" />
                                    <HBox alignItems="Center">
                                        <Text text="{viewModel>Phone}" class="sapUiSmallMarginEnd" />
                                        <ObjectStatus text="{viewModel>CustomerId}" state="Information" inverted="true" />
                                    </HBox>
                                </VBox>
                                <VBox>
                                    <Text text="{viewModel>CarPlate}" class="sapMTextBold" />
                                    <Text text="{viewModel>VehicleModel}" />
                                </VBox>
                                <Text text="{viewModel>ServiceType}" />
                                <ObjectStatus text="{viewModel>PaymentMethod}" inverted="true" state="{= ${viewModel>PaymentMethod} === 'UPI' ? 'Information' : 'Warning'}" />
                                <Text text="₹{viewModel>Amount}" class="sapMTextBold" />
                                <Text text="{path: 'viewModel>Date', formatter: '.formatter.formatDateString'}" />
                                <HBox alignItems="Center" justifyContent="Center">
                                    <Button icon="sap-icon://print" type="Transparent" press=".onButtonPrintBillPress" class="sapUiSmallMarginEnd" tooltip="Print" />
                                    <Button icon="sap-icon://delete" type="Transparent" press=".onButtonDeletePress" tooltip="Delete" />
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <!-- Mobile List -->
                <List id="idPagedServicesMobileList" items="{viewModel>/pagedServices}" noDataText="No matching service records found." class="stitchCardList showOnMobile sapUiSizeCompact">
                    <items>
                        <CustomListItem class="stitchCard">
                            <VBox class="stitchFlex">
                                <HBox justifyContent="SpaceBetween" alignItems="Start" class="stitchCardTop">
                                    <HBox>
                                        <core:Icon src="sap-icon://sys-enter-2" class="stitchCheckIcon" visible="{viewModel>/tableColumns/Customer}" />
                                        <VBox class="stitchNameVBox">
                                            <Text text="{viewModel>CustomerName}" class="stitchCustomerName" visible="{viewModel>/tableColumns/Customer}" />
                                            <HBox alignItems="Center" class="stitchCustHBox" visible="{viewModel>/tableColumns/Customer}">
                                                <core:Icon src="sap-icon://customer" class="stitchCustIcon" />
                                                <Text text="{viewModel>CustomerId}" class="stitchCustIdText" />
                                            </HBox>
                                            <Text text="{viewModel>CarPlate}" class="stitchCarPlate" visible="{viewModel>/tableColumns/Vehicle}" />
                                        </VBox>
                                    </HBox>
                                    <VBox alignItems="End" visible="{viewModel>/tableColumns/Amount}" class="stitchAmountVBox">
                                        <Text text="₹{viewModel>Amount}" class="stitchAmount" />
                                        <Text text="{viewModel>PaymentMethod}" class="stitchPaymentPill {= 'pill' + ${viewModel>PaymentMethod} }" visible="{viewModel>/tableColumns/Payment}" />
                                    </VBox>
                                </HBox>
                                <HBox justifyContent="SpaceBetween" alignItems="Center" class="stitchMiddleSection">
                                    <HBox alignItems="Center" visible="{viewModel>/tableColumns/Customer}">
                                        <core:Icon src="sap-icon://call" class="stitchGreyIcon" />
                                        <Text text="{viewModel>Phone}" class="stitchMetaText" />
                                    </HBox>
                                    <HBox alignItems="Center" visible="{viewModel>/tableColumns/Date}">
                                        <core:Icon src="sap-icon://calendar" class="stitchGreyIcon" />
                                        <Text text="{path: 'viewModel>Date', formatter: '.formatter.formatDateString'}" class="stitchMetaText" />
                                    </HBox>
                                </HBox>
                                <HBox visible="{viewModel>/tableColumns/Services}" class="stitchServicesSection">
                                    <Text text="Services: " class="stitchLabelText" />
                                    <Text text="{viewModel>ServiceType}" class="stitchMetaText" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" alignItems="Center" visible="{viewModel>/tableColumns/Actions}" class="stitchButtonSection">
                                    <Button text="Print Bill" icon="sap-icon://print" press=".onPrintBillButtonPress" class="stitchActionBtn stitchActionBtnBlue" />
                                    <Button text="Delete" icon="sap-icon://delete" press=".onDeleteButtonPress" class="stitchActionBtn stitchActionBtnRed" />
                                </HBox>
                            </VBox>
                        </CustomListItem>
                    </items>
                </List>

                <!-- Pagination -->
                <HBox justifyContent="Center" alignItems="Center" class="sapUiMediumMarginTopBottom">
                    <Button text="&lt; Previous" type="Transparent" press=".onLtPreviousButtonPress" enabled="{viewModel>/hasPrevPage}" class="sapUiSmallMarginEnd" />
                    <HBox class="sapUiSmallMarginBeginEnd">
                        <Button text="1" type="{= ${viewModel>/currentPage} === 1 ? 'Emphasized' : 'Transparent'}" press=".onButtonPageSelectPress" class="sapUiTinyMarginEnd" />
                        <Button text="2" type="{= ${viewModel>/currentPage} === 2 ? 'Emphasized' : 'Transparent'}" press=".onButtonPageSelectPress" enabled="{= ${viewModel>/totalPages} >= 2}" class="sapUiTinyMarginEnd" />
                    </HBox>
                    <Button text="Next &gt;" type="Transparent" press=".onNextGtButtonPress" enabled="{viewModel>/hasNextPage}" class="sapUiSmallMarginBegin" />
                </HBox>
            </Panel>
        </VBox>
    </Page>
</mvc:View>
