<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="View Settings" stretch="{device>/system/phone}" contentWidth="350px" verticalScrolling="true" class="sapUiContentPadding">
        <customHeader>
            <Bar>
                <contentMiddle>
                    <Title text="Columns" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <content>
            <List id="idColumnsSettingsList" mode="MultiSelect" includeItemInSelection="true" items="{colsModel>/columns}">
                <StandardListItem title="{colsModel>name}" selected="{colsModel>visible}" />
            </List>
        </content>
        <buttons>
            <Button text="OK" type="Emphasized" press=".onOKButtonPress" />
            <Button text="Cancel" press=".onCancelButtonPress" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
