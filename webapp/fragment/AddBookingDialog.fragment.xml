<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form">
	<Dialog
		id="idAddBookingDialog"
		title="Add New Booking"
		contentWidth="400px"
		contentHeight="250px">
		<content>
			<f:SimpleForm
				editable="true"
				labelSpanXL="4"
				labelSpanM="4"
				adjustLabelSpan="false"
				emptySpanXL="0"
				columnsXL="1"
				columnsL="1"
				singleContainerFullSize="false">
				<f:content>
					<Label text="Car Plate Number" required="true"/>
					<Input
						id="idCarPlateInput"
						placeholder="e.g. ABC-1234"/>
					
					<Label text="Customer Name" required="true"/>
					<Input
						id="idCustomerInput"
						placeholder="Customer's Full Name"/>
					
					<Label text="Service Type" required="true"/>
					<Select id="idServiceSelect" selectedKey="Basic Wash">
						<items>
							<core:Item text="Basic Wash" key="Basic Wash"/>
							<core:Item text="Premium Wash" key="Premium Wash"/>
							<core:Item text="Interior Detailing" key="Interior Detailing"/>
							<core:Item text="Ceramic Coating" key="Ceramic Coating"/>
							<core:Item text="Full Detailing" key="Full Detailing"/>
						</items>
					</Select>
				</f:content>
			</f:SimpleForm>
		</content>
		<beginButton>
			<Button
				text="Save"
				type="Emphasized"
				press=".onSaveBooking"/>
		</beginButton>
		<endButton>
			<Button
				text="Cancel"
				press=".onCancelBooking"/>
		</endButton>
	</Dialog>
</core:FragmentDefinition>
